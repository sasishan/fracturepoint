# Game Server
GAME_SERVER_PORT=3001
GAME_SERVER_HOST=0.0.0.0

# Lobby Server
LOBBY_SERVER_PORT=3000
LOBBY_SERVER_HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ww3
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AWS / S3
AWS_REGION=us-east-1
AWS_BUCKET_NAME=ww3-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Environment
NODE_ENV=development
LOG_LEVEL=info
