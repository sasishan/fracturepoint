# Copy this to .env and fill in the values

# Lobby server (auth, matchmaking, game creation)
VITE_LOBBY_URL=http://localhost:3000

# Game server (socket.io real-time gameplay)
VITE_GAME_SERVER_URL=http://localhost:3001

# Mixpanel analytics — leave blank to disable tracking (safe in dev)
# Get your project token from mixpanel.com → Settings → Project Token
VITE_MIXPANEL_TOKEN=

# For production (Vercel environment variables):
# VITE_LOBBY_URL=https://ww3-lobby.onrender.com
# VITE_GAME_SERVER_URL=https://ww3-game.onrender.com
# VITE_MIXPANEL_TOKEN=your_production_token_here
