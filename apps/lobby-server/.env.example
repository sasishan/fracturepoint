# Lobby server environment variables
# Copy to .env for local dev

LOBBY_SERVER_PORT=3000

# JWT secret — use a long random string in production
JWT_SECRET=dev-secret-CHANGE-IN-PRODUCTION

# Comma-separated list of allowed client origins
CORS_ORIGIN=http://localhost:5173,http://localhost:8420

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/ww3

# Redis connection string
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
NODE_ENV=development
